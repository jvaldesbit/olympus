---
import { u } from '../utils/url';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProfileCard from '../components/ProfileCard.astro';
import escortsData from '../data/escorts.json';

const featuredProfiles = escortsData
  .filter(e => e.images.length > 1)
  .slice(0, 4)
  .map(e => ({
    name: e.name,
    age: e.age,
    city: e.city,
    tags: e.services.slice(0, 3).length > 0 ? e.services.slice(0, 3) : [e.skin, e.hair].filter(Boolean),
    image: e.images[0],
    slug: e.slug,
    featured: e.available,
  }));
---

<Layout title="Inicio">
  <Navbar />

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <video
        id="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        class="w-full h-full object-cover opacity-60"
      >
        <source src={u('/home.mp4')} type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/50 via-[#0a0a0a]/30 to-[#0a0a0a]" />
    </div>

    <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
      <h1 class="text-6xl md:text-8xl lg:text-9xl text-white mb-4 leading-none" style="font-family: 'Anton', sans-serif; letter-spacing: 0.08em;">
        OLYMPUS
      </h1>
      <div class="gold-divider mb-8"></div>

      <p class="text-white/90 text-xl md:text-3xl font-light tracking-wide mb-3">
        Las mejores <span class="text-[#c9a84c] font-semibold">escorts</span> y <span class="text-[#c9a84c] font-semibold">acompañantes</span> de Colombia
      </p>
      <p class="text-gray-400 text-sm md:text-base tracking-[0.3em] uppercase mb-10">
        Prepagos · Privadas · Verificadas · Discretas
      </p>

      <div class="flex justify-center">
        <a href={u("/perfiles")} class="btn-gold">Ver Escorts</a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-[#c9a84c]/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- Sobre Nosotros -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-[#c9a84c] text-xs tracking-[0.4em] uppercase mb-4">Quiénes Somos</p>
      <h2 class="section-title">La Cima del Lujo y la Discreción</h2>
      <div class="gold-divider"></div>
      <p class="text-gray-400 text-base md:text-lg leading-relaxed max-w-3xl mx-auto mt-6">
        En Olympus reunimos a las escorts más selectas del país. Cada una es cuidadosamente verificada para garantizar experiencias memorables, seguras y completamente discretas. Tu satisfacción y privacidad son nuestra prioridad absoluta.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
        {[
          { number: '100+', label: 'Escorts Activas', icon: '◈' },
          { number: '5★', label: 'Calificación Promedio', icon: '◆' },
          { number: '24/7', label: 'Atención al Cliente', icon: '◉' },
        ].map(stat => (
          <div class="border border-[#c9a84c]/20 p-8 bg-[#111111] hover:border-[#c9a84c]/50 transition-colors duration-300">
            <div class="text-[#c9a84c] text-2xl mb-3">{stat.icon}</div>
            <div class="text-white text-4xl font-bold mb-2" style=\"font-family:'Anton',sans-serif; letter-spacing:0.06em;\">{stat.number}</div>
            <div class="text-gray-500 text-sm tracking-widest uppercase">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Perfiles Destacados -->
  <section class="py-24 px-6 bg-[#0f0f0f]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-[#c9a84c] text-xs tracking-[0.4em] uppercase mb-4">Selección Premium</p>
        <h2 class="section-title">Escorts Destacadas</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredProfiles.map(profile => (
          <ProfileCard {...profile} />
        ))}
      </div>

      <div class="text-center mt-12">
        <a href={u("/perfiles")} class="btn-outline">Ver Todas las Escorts</a>
      </div>
    </div>
  </section>

  <!-- Servicios -->
  <section id="servicios" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-[#c9a84c] text-xs tracking-[0.4em] uppercase mb-4">Lo Que Ofrecemos</p>
        <h2 class="section-title">Nuestros Servicios</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            title: 'Compañía Social',
            desc: 'Acompañamiento para eventos, cenas y reuniones sociales de alto nivel.',
            icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
          },
          {
            title: 'Viajes VIP',
            desc: 'Acompañamiento en viajes nacionales e internacionales con total discreción.',
            icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
          },
          {
            title: 'Eventos Corporativos',
            desc: 'Presencia elegante y profesional en eventos de negocios y gala.',
            icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
          },
          {
            title: 'Reservas Privadas',
            desc: 'Encuentros íntimos en entornos exclusivos y totalmente seguros.',
            icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
          },
          {
            title: 'Membresías Premium',
            desc: 'Acceso prioritario y beneficios exclusivos para clientes frecuentes.',
            icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
          },
          {
            title: 'Atención 24/7',
            desc: 'Línea directa disponible las 24 horas para reservas y consultas.',
            icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
          },
        ].map(service => (
          <div class="p-8 bg-[#111111] border border-[#c9a84c]/10 hover:border-[#c9a84c]/40 transition-all duration-300 group">
            <div class="w-12 h-12 border border-[#c9a84c]/30 flex items-center justify-center mb-6 group-hover:border-[#c9a84c] transition-colors duration-300">
              <svg class="w-5 h-5 text-[#c9a84c]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon}/>
              </svg>
            </div>
            <h3 class="text-white text-lg font-semibold mb-3" style=\"font-family:'Anton',sans-serif; letter-spacing:0.06em;\">{service.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonios -->
  <section class="py-24 px-6 bg-[#0f0f0f]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-[#c9a84c] text-xs tracking-[0.4em] uppercase mb-4">Opiniones</p>
        <h2 class="section-title">Lo Que Dicen Nuestros Clientes</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            text: 'Una experiencia verdaderamente excepcional. La discreción y profesionalismo de Olympus no tiene comparación.',
            author: 'C.M.',
            city: 'Bogotá',
          },
          {
            text: 'El nivel de atención al detalle y la calidad de sus escorts superó todas mis expectativas. Volveré sin dudarlo.',
            author: 'R.A.',
            city: 'Medellín',
          },
          {
            text: 'Servicio impecable desde la primera llamada hasta el final. Total profesionalismo y confidencialidad.',
            author: 'J.L.',
            city: 'Cali',
          },
        ].map(review => (
          <div class="p-8 bg-[#111111] border border-[#c9a84c]/10">
            <div class="flex mb-4">
              {Array(5).fill(null).map(() => (
                <svg class="w-4 h-4 text-[#c9a84c]" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-gray-400 text-sm leading-relaxed italic mb-6">"{review.text}"</p>
            <div class="flex items-center gap-3">
              <div class="w-8 h-px bg-[#c9a84c]/40"></div>
              <span class="text-gray-600 text-xs tracking-widest uppercase">{review.author} · {review.city}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contacto -->
  <section id="contacto" class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-[#c9a84c] text-xs tracking-[0.4em] uppercase mb-4">Hablemos</p>
        <h2 class="section-title">Solicitar Reserva</h2>
        <div class="gold-divider"></div>
        <p class="text-gray-500 text-sm mt-4">Toda la información es estrictamente confidencial.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <form class="space-y-5" id="contact-form">
          <div>
            <label class="block text-[#c9a84c] text-xs tracking-widest uppercase mb-2">Nombre</label>
            <input
              type="text"
              placeholder="Tu nombre"
              class="w-full bg-[#111111] border border-[#c9a84c]/20 text-white px-4 py-3 text-sm focus:outline-none focus:border-[#c9a84c]/60 transition-colors placeholder-gray-700"
            />
          </div>
          <div>
            <label class="block text-[#c9a84c] text-xs tracking-widest uppercase mb-2">WhatsApp / Teléfono</label>
            <input
              type="tel"
              placeholder="+57 300 000 0000"
              class="w-full bg-[#111111] border border-[#c9a84c]/20 text-white px-4 py-3 text-sm focus:outline-none focus:border-[#c9a84c]/60 transition-colors placeholder-gray-700"
            />
          </div>
          <div>
            <label class="block text-[#c9a84c] text-xs tracking-widest uppercase mb-2">Ciudad</label>
            <select class="w-full bg-[#111111] border border-[#c9a84c]/20 text-gray-400 px-4 py-3 text-sm focus:outline-none focus:border-[#c9a84c]/60 transition-colors">
              <option value="">Selecciona ciudad</option>
              <option>Bogotá</option>
              <option>Medellín</option>
              <option>Cali</option>
              <option>Barranquilla</option>
              <option>Otra</option>
            </select>
          </div>
          <div>
            <label class="block text-[#c9a84c] text-xs tracking-widest uppercase mb-2">Mensaje</label>
            <textarea
              rows="4"
              placeholder="Cuéntanos qué tienes en mente..."
              class="w-full bg-[#111111] border border-[#c9a84c]/20 text-white px-4 py-3 text-sm focus:outline-none focus:border-[#c9a84c]/60 transition-colors placeholder-gray-700 resize-none"
            ></textarea>
          </div>
          <button type="submit" class="btn-gold w-full text-center">Enviar Solicitud</button>
        </form>

        <div class="flex flex-col justify-center gap-8">
          <div>
            <h3 class="text-white font-semibold mb-6" style=\"font-family:'Anton',sans-serif; letter-spacing:0.06em;\">Contacto Directo</h3>
            <div class="space-y-5">
              {[
                { label: 'WhatsApp', value: '+1 (234) 567-890', href: 'https://wa.me/1234567890' },
                { label: 'Teléfono', value: '+1 (234) 567-890', href: 'tel:+1234567890' },
                { label: 'Email', value: 'info@olympus.agency', href: 'mailto:info@olympus.agency' },
              ].map(item => (
                <div class="flex items-center gap-4 group">
                  <div class="w-px h-8 bg-[#c9a84c]/40"></div>
                  <div>
                    <p class="text-[#c9a84c] text-[10px] tracking-widest uppercase mb-0.5">{item.label}</p>
                    <a href={item.href} class="text-gray-400 text-sm hover:text-white transition-colors">{item.value}</a>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="border border-[#c9a84c]/20 p-6">
            <p class="text-[#c9a84c] text-xs tracking-widest uppercase mb-3">Confidencialidad</p>
            <p class="text-gray-500 text-sm leading-relaxed">
              Tu privacidad es sagrada para nosotros. Toda comunicación es encriptada y nunca compartimos datos de clientes.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  if (video) {
    video.muted = true;

    const tryPlay = () => {
      video.play().catch(() => {});
    };

    // Intento inmediato
    tryPlay();

    // Si el navegador lo bloquea, reproducir en primer toque/click
    const onInteraction = () => {
      tryPlay();
      document.removeEventListener('touchstart', onInteraction);
      document.removeEventListener('click', onInteraction);
    };
    document.addEventListener('touchstart', onInteraction, { once: true, passive: true });
    document.addEventListener('click', onInteraction, { once: true });

    // Intersection Observer: reproducir cuando el banner sea visible
    const observer = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) tryPlay();
    }, { threshold: 0.1 });
    observer.observe(video);
  }
</script>
