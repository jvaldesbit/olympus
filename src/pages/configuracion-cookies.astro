---
import { u } from '../utils/url';
import LegalLayout from '../layouts/LegalLayout.astro';
---

<LegalLayout title="Configuración de Cookies" description="Gestiona tu configuración de cookies en Olympus Agency.">

  <div class="legal-note">
    <strong>Tu control:</strong> Puedes activar o desactivar las cookies opcionales en cualquier momento. Las cookies técnicas siempre están activas porque son necesarias para que el sitio funcione.
  </div>

  <div style="display:flex; flex-direction:column; gap:1rem; margin-bottom:2.5rem;" id="cookie-settings">

    <!-- Técnicas -->
    <div style="background:#111; border:1px solid #c9a84c1a; padding:1.5rem; display:flex; align-items:flex-start; justify-content:space-between; gap:1.5rem;">
      <div>
        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.5rem;">
          <h3 style="font-family:'Anton',sans-serif; letter-spacing:0.06em; font-size:1rem; color:white; text-transform:uppercase; margin:0;">Cookies Técnicas</h3>
          <span class="legal-badge">Siempre activas</span>
        </div>
        <p style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:#6b7280; font-weight:300; line-height:1.6; margin:0;">
          <strong style="color:#d1d5db; font-weight:600;">Necesarias para el funcionamiento del sitio.</strong> Gestionan la sesión del usuario, la verificación de edad y el correcto renderizado de la web. No se pueden desactivar.
        </p>
      </div>
    </div>

    <!-- Analíticas -->
    <div style="background:#111; border:1px solid #c9a84c1a; padding:1.5rem; display:flex; align-items:flex-start; justify-content:space-between; gap:1.5rem;" id="analytics-card">
      <div style="flex:1;">
        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.5rem;">
          <h3 style="font-family:'Anton',sans-serif; letter-spacing:0.06em; font-size:1rem; color:white; text-transform:uppercase; margin:0;">Cookies Analíticas</h3>
          <span class="legal-badge" style="background:#c9a84c1a; border-color:#c9a84c33; color:#c9a84c;">Anonymize IP</span>
        </div>
        <p style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:#6b7280; font-weight:300; line-height:1.6; margin:0;">
          <strong style="color:#d1d5db; font-weight:600;">No recabamos datos personales.</strong> Solo nos permiten conocer el número de visitantes y las páginas más consultadas. La dirección IP se anonimiza completamente antes de cualquier procesamiento.
        </p>
      </div>
      <div style="flex-shrink:0; padding-top:0.25rem;">
        <label style="position:relative; display:inline-flex; align-items:center; cursor:pointer;">
          <input type="checkbox" id="analytics-toggle" style="position:absolute; opacity:0; width:0; height:0;" checked />
          <div id="toggle-track" style="width:44px; height:24px; background:#c9a84c; border-radius:999px; transition:background 0.3s; position:relative;">
            <div id="toggle-thumb" style="position:absolute; top:2px; left:22px; width:20px; height:20px; background:white; border-radius:50%; transition:left 0.3s;"></div>
          </div>
        </label>
      </div>
    </div>

    <!-- Sesión -->
    <div style="background:#111; border:1px solid #c9a84c1a; padding:1.5rem; display:flex; align-items:flex-start; justify-content:space-between; gap:1.5rem;">
      <div>
        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.5rem;">
          <h3 style="font-family:'Anton',sans-serif; letter-spacing:0.06em; font-size:1rem; color:white; text-transform:uppercase; margin:0;">Cookies de Sesión</h3>
          <span class="legal-badge">Siempre activas</span>
        </div>
        <p style="font-family:'Manrope',sans-serif; font-size:0.8rem; color:#6b7280; font-weight:300; line-height:1.6; margin:0;">
          <strong style="color:#d1d5db; font-weight:600;">Se eliminan al cerrar el navegador.</strong> Almacenan preferencias temporales durante tu visita, como la confirmación de mayoría de edad. No persisten entre sesiones.
        </p>
      </div>
    </div>

  </div>

  <div style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1.5rem;">
    <button id="save-settings" class="btn-gold" style="max-width:280px;">Guardar configuración</button>
    <a href={u("/politica-cookies")} style="font-family:'Manrope',sans-serif; font-size:0.75rem; color:#c9a84c; letter-spacing:0.1em; text-transform:uppercase;">→ Ver Política de Cookies completa</a>
  </div>

  <div id="saved-msg" style="display:none; font-family:'Manrope',sans-serif; font-size:0.85rem; color:#c9a84c; background:#c9a84c0d; border:1px solid #c9a84c33; padding:0.75rem 1rem;">
    ✓ Configuración guardada correctamente.
  </div>

  <p class="legal-footer-note">Última actualización: junio 2025 · <a href={u("/privacidad")} style="color:#c9a84c;">Política de Privacidad</a></p>

</LegalLayout>

<script>
  const toggle = document.getElementById('analytics-toggle') as HTMLInputElement;
  const track = document.getElementById('toggle-track')!;
  const thumb = document.getElementById('toggle-thumb')!;
  const saveBtn = document.getElementById('save-settings')!;
  const savedMsg = document.getElementById('saved-msg')!;

  function updateToggleUI(checked: boolean) {
    track.style.background = checked ? '#c9a84c' : '#374151';
    thumb.style.left = checked ? '22px' : '2px';
  }

  const saved = localStorage.getItem('cookies-analytics');
  if (saved !== null) {
    toggle.checked = saved === '1';
  }
  updateToggleUI(toggle.checked);

  toggle.addEventListener('change', () => updateToggleUI(toggle.checked));

  saveBtn.addEventListener('click', () => {
    localStorage.setItem('cookies-analytics', toggle.checked ? '1' : '0');
    savedMsg.style.display = 'block';
    setTimeout(() => { savedMsg.style.display = 'none'; }, 3000);
  });
</script>
