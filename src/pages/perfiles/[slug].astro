---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'valentina' } },
    { params: { slug: 'isabella' } },
    { params: { slug: 'camila' } },
    { params: { slug: 'sofia' } },
    { params: { slug: 'natalia' } },
    { params: { slug: 'alejandra' } },
    { params: { slug: 'daniela' } },
    { params: { slug: 'mariana' } },
  ];
}

const profiles: Record<string, {
  name: string;
  age: number;
  city: string;
  tags: string[];
  image: string;
  gallery: string[];
  bio: string;
  services: string[];
  height: string;
  nationality: string;
