    height: '1.70m',
    nationality: 'Colombiana',
    languages: ['Español', 'Inglés', 'Portugués'],
  },
  natalia: {
    name: 'Natalia',
    age: 25,
    city: 'Medellín',
    tags: ['Cenas', 'Eventos', 'Exclusiva'],
    image: 'https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=800&q=80',
    gallery: [],
    bio: 'Natalia posee una presencia que no pasa desapercibida. Modelo profesional con años de experiencia en el mundo del entretenimiento, ofrece una compañía única e irrepetible.',
    services: ['Eventos exclusivos', 'Cenas románticas', 'Sesiones fotográficas', 'Compañía privada'],
    height: '1.75m',
