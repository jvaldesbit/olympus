---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ProfileCard from '../../components/ProfileCard.astro';
import escortsData from '../../data/escorts.json';

// Normalizar precios para mostrar
function formatPrice(p: string) {
  const n = parseInt(p);
  return isNaN(n) ? p : n.toLocaleString('es-CO');
}

// Solo mostrar escorts que tengan más de una foto
const profiles = escortsData
  .filter(e => e.images.length > 1)
  .map(e => ({
    name: e.name,
    age: e.age,
    city: e.city,
    tags: e.services.slice(0, 3).length > 0 ? e.services.slice(0, 3) : [e.skin, e.hair].filter(Boolean),
    image: e.images[0],
    slug: e.slug,
    featured: e.available,
  }));

const cities = ['Todas', ...Array.from(new Set(escortsData.map(e => e.city))).sort()];
---

<Layout title="Escorts" description="Las mejores escorts y acompañantes de Colombia en Olympus Agency.">
  <Navbar />

  <div class="pt-28 pb-24 px-6 min-h-screen">
    <div class="max-w-7xl mx-auto">

      <div class="text-center mb-14">
        <p class="text-[#c9a84c] text-xs tracking-[0.4em] uppercase mb-4 font-['Manrope']">Selección Exclusiva</p>
        <h1 class="section-title">Nuestras Escorts</h1>
        <div class="gold-divider"></div>
        <p class="text-gray-500 text-sm mt-4 max-w-xl mx-auto font-['Manrope']">
          {profiles.length} perfiles verificados · Colombia
        </p>
      </div>

      <!-- Filtros por ciudad -->
      <div class="flex flex-wrap justify-center gap-3 mb-12" id="filters">
        {cities.map((city, i) => (
          <button
            data-filter={city === 'Todas' ? 'all' : city}
            class:list={[
              'filter-btn text-xs tracking-widest uppercase px-5 py-2 border transition-all duration-300 font-["Manrope"]',
              i === 0
                ? 'border-[#c9a84c] text-[#c9a84c] bg-[#c9a84c]/10'
                : 'border-[#c9a84c]/20 text-gray-500 hover:border-[#c9a84c]/50 hover:text-gray-300'
            ]}
          >
            {city}
          </button>
        ))}
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3" id="profiles-grid">
        {profiles.map(profile => (
          <div data-city={profile.city} class="profile-item">
            <ProfileCard {...profile} />
          </div>
        ))}
      </div>

      <!-- Contador visible -->
      <p id="count-label" class="text-center text-gray-600 text-xs font-['Manrope'] tracking-widest mt-10 uppercase">
        Mostrando {profiles.length} escorts
      </p>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const profileItems = document.querySelectorAll('.profile-item') as NodeListOf<HTMLElement>;
  const countLabel = document.getElementById('count-label')!;

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('border-[#c9a84c]', 'text-[#c9a84c]', 'bg-[#c9a84c]/10');
        b.classList.add('border-[#c9a84c]/20', 'text-gray-500');
      });
      btn.classList.add('border-[#c9a84c]', 'text-[#c9a84c]', 'bg-[#c9a84c]/10');
      btn.classList.remove('border-[#c9a84c]/20', 'text-gray-500');

      const filter = (btn as HTMLElement).dataset.filter!;
      let visible = 0;
      profileItems.forEach(item => {
        const show = filter === 'all' || item.dataset.city === filter;
        item.style.display = show ? 'block' : 'none';
        if (show) visible++;
      });
      countLabel.textContent = `Mostrando ${visible} escort${visible !== 1 ? 's' : ''}`;
    });
  });
</script>
