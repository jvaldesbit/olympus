---
const year = new Date().getFullYear();
---

<footer class="bg-[#0a0a0a] border-t border-[#c9a84c]/20 py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <h3 class="text-white text-xl font-bold tracking-[0.2em] uppercase mb-4" style="font-family: 'Playfair Display', serif;">
          OLYMPUS
        </h3>
        <p class="text-gray-500 text-sm leading-relaxed">
          Agencia de acompañantes de lujo. Discreción, elegancia y experiencias únicas para clientes selectos.
        </p>
      </div>

      <div>
        <h4 class="text-[#c9a84c] text-xs tracking-widest uppercase mb-5">Navegación</h4>
        <ul class="space-y-3">
          {['Inicio', 'Perfiles', 'Servicios', 'Contacto'].map(item => (
            <li>
              <a href={item === 'Inicio' ? '/' : item === 'Perfiles' ? '/perfiles' : `/#${item.toLowerCase()}`}
                class="text-gray-500 text-sm hover:text-[#c9a84c] transition-colors duration-300 tracking-wide">
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-[#c9a84c] text-xs tracking-widest uppercase mb-5">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-center gap-3 text-gray-500 text-sm">
            <svg class="w-4 h-4 text-[#c9a84c] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+1234567890" class="hover:text-[#c9a84c] transition-colors">+1 (234) 567-890</a>
          </li>
          <li class="flex items-center gap-3 text-gray-500 text-sm">
            <svg class="w-4 h-4 text-[#c9a84c] shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.553 4.122 1.522 5.858L0 24l6.335-1.498A11.938 11.938 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.797 9.797 0 01-5.017-1.378l-.36-.214-3.724.88.93-3.613-.234-.372A9.757 9.757 0 012.182 12C2.182 6.58 6.58 2.182 12 2.182S21.818 6.58 21.818 12 17.42 21.818 12 21.818z"/>
            </svg>
            <a href="https://wa.me/1234567890" target="_blank" rel="noopener" class="hover:text-[#c9a84c] transition-colors">WhatsApp</a>
          </li>
          <li class="flex items-center gap-3 text-gray-500 text-sm">
            <svg class="w-4 h-4 text-[#c9a84c] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@olympus.agency" class="hover:text-[#c9a84c] transition-colors">info@olympus.agency</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[#c9a84c]/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-600 text-xs tracking-wide">
        &copy; {year} Olympus Agency. Todos los derechos reservados.
      </p>
      <p class="text-gray-700 text-xs">
        Servicio exclusivo para mayores de 18 años.
      </p>
    </div>
  </div>
</footer>
