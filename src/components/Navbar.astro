---
const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Perfiles', href: '/perfiles' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Contacto', href: '/#contacto' },
];

const currentPath = Astro.url.pathname;
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" data-navbar>
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <span class="text-2xl font-bold tracking-[0.2em] uppercase text-white group-hover:text-[#c9a84c] transition-colors duration-300" style="font-family: 'Playfair Display', serif;">
        OLYMPUS
      </span>
      <span class="text-[#c9a84c] text-xs tracking-[0.3em] uppercase hidden sm:block">Agencia</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm tracking-widest uppercase transition-colors duration-300',
            currentPath === link.href
              ? 'text-[#c9a84c]'
              : 'text-gray-300 hover:text-[#c9a84c]'
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:flex items-center gap-4">
      <a href="/#contacto" class="btn-gold text-xs py-2 px-5">
        Reservar
      </a>
    </div>

    <button id="menu-toggle" class="md:hidden text-white p-2" aria-label="Abrir menú">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-[#0a0a0a]/98 border-t border-[#c9a84c]/20">
    <div class="px-6 py-6 flex flex-col gap-5">
      {navLinks.map(link => (
        <a href={link.href} class="text-gray-300 hover:text-[#c9a84c] text-sm tracking-widest uppercase transition-colors">
          {link.label}
        </a>
      ))}
      <a href="/#contacto" class="btn-gold text-center mt-2">Reservar</a>
    </div>
  </div>
</header>

<script>
  const navbar = document.querySelector('[data-navbar]') as HTMLElement;
  const toggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar.classList.add('bg-[#0a0a0a]/95', 'backdrop-blur-md', 'border-b', 'border-[#c9a84c]/10');
    } else {
      navbar.classList.remove('bg-[#0a0a0a]/95', 'backdrop-blur-md', 'border-b', 'border-[#c9a84c]/10');
    }
  });

  toggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
