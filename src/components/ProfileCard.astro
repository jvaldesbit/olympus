---
import { u } from '../utils/url';
interface Props {
  name: string;
  age: number;
  city: string;
  tags: string[];
  image: string;
  slug: string;
  featured?: boolean;
}

const { name, age, city, tags, image, slug, featured = false } = Astro.props;
---

<a href={u(`/perfiles/${slug}`)} class="card-profile block">
  <div class="relative overflow-hidden aspect-[3/4]">
    <img
      src={image}
      alt={name}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />

    {featured && (
      <div class="absolute top-4 right-4 flex items-center gap-1.5 bg-black/40 backdrop-blur-sm border border-green-500/30 rounded-full px-3 py-1">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        <span class="text-[10px] text-green-400 tracking-widest uppercase font-['Manrope'] font-semibold">Libre</span>
      </div>
    )}

    <div class="absolute bottom-0 left-0 right-0 p-5">
      <div class="flex items-end justify-between mb-3">
        <div>
          <h3 class="text-white text-xl tracking-wide" style="font-family:'Anton',sans-serif; letter-spacing:0.06em;">{name}</h3>
          <p class="text-gray-400 text-sm font-['Manrope']">{age} años · {city}</p>
        </div>
        <svg class="w-8 h-8 text-[#c9a84c] opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </div>
      <div class="flex flex-wrap gap-2">
        {featured && (
          <span class="text-[10px] tracking-widest uppercase text-black bg-[#c9a84c] px-2 py-0.5 font-bold">
            Destacada
          </span>
        )}
        {tags.slice(0, 3).map(tag => (
          <span class="text-[10px] tracking-widest uppercase text-[#c9a84c]/80 border border-[#c9a84c]/30 px-2 py-0.5">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</a>
